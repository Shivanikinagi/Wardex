# Wardex Environment Variables
# Copy this to .env and fill in your values

# Deployer private key (DO NOT COMMIT)
PRIVATE_KEY=your_new_private_key_without_0x

# Base Sepolia RPC
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Basescan API Key for verification
BASESCAN_API_KEY=your_new_basescan_api_key

# ENS Configuration (optional - for ENS integration)
ENS_REGISTRY_ADDRESS=
ENS_RESOLVER_ADDRESS=

# Deployed contract addresses (Base Sepolia)
WARDEX_CONTRACT=
CAPABILITY_CHECK_CONTRACT=
VERIFIER_CONTRACT=

# Runtime integrations
DEPLOYER_ADDRESS=
VENICE_API_KEY=
VENICE_MODEL=llama-3.3-70b
VENICE_COST_USDC=0.001
VENICE_PAYMENT_ADDRESS=

# Agent treasury (Lido track)
AGENT_TREASURY_CONTRACT=
# Optional: provide a valid 0x...40-hex address. If empty, deploy script will use MockWstETH for demo.
WSTETH_CONTRACT=
STETH_USD_PRICE=1
TREASURY_PER_TX_CAP_STETH=0.05
TREASURY_DEPOSIT_TX_HASH=

# Filecoin logging
FILECOIN_UCAN_ENABLED=true
FILECOIN_FOC_ENABLED=true
FILECOIN_RPC_URL=
FILECOIN_PRIVATE_KEY=
FILECOIN_WALLET_ADDRESS=
FILECOIN_SETUP_DEPOSIT_USDFC=0.5
FILECOIN_UPLOAD_ENDPOINT=
FILECOIN_API_KEY=
WEB3_STORAGE_TOKEN=
FILECOIN_RETRIEVE_GATEWAYS=
FILECOIN_W3UP_EMAIL=
FILECOIN_UPDATE_ENV=false
FILECOIN_SPACE_DID=
FILECOIN_LAST_TEST_CID=
FILECOIN_PIECE_CID=
WARDEX_FILECOIN_UPLOAD_TIMEOUT_MS=15000
WARDEX_FILECOIN_TOTAL_TIMEOUT_MS=45000
FILECOIN_UPLOAD_RETRIES=2
FILECOIN_RETRY_DELAY_MS=1200

# Lit sealed policy
# SDK-first config for executing sealed Lit Actions (Dark Knowledge Skills).
LIT_SDK_PACKAGE=
LIT_NETWORK=datil-dev
LIT_SESSION_SIGS_JSON=
LIT_AUTH_SIG=
LIT_POLICY_API_URL=
# Legacy fallback only (optional).
LIT_API_KEY=
LIT_ACTION_CID=
LIT_ACTION_SOURCE_PATH=lit/policyAction.js
LIT_CHAIN=base

# Zyfai yield funding
# Real Zyfai SDK config (Safe + session key flow)
ZYFAI_SDK_PACKAGE=
ZYFAI_API_KEY=
WALLET_ADDRESS=
ZYFAI_CHAIN_ID=8453
ZYFAI_STRATEGY=conservative
ZYFAI_BOOTSTRAP_DEPOSIT_USDC=1
ZYFAI_SAFE_ADDRESS=
# Optional simulation mode when Zyfai APIs are unavailable.
ZYFAI_SIMULATED_YIELD_USDC=

# x402 payment metadata
X402_AMOUNT=0.001
X402_CURRENCY=USDC
X402_NETWORK=base-sepolia

# Status network deploy
STATUS_SEPOLIA_RPC=https://public.sepolia.rpc.status.network
STATUS_DEPLOY_TX_HASH=
STATUS_EXECUTION_TX_HASH=

# Optional Base evidence links surfaced in the frontend sponsor proof cards
BASE_PROPOSE_TX_HASH=
BASE_VERIFY_TX_HASH=
BASE_EXECUTE_TX_HASH=

# Optional agent addresses
TRADING_AGENT_ADDRESS=
DATA_AGENT_ADDRESS=
TRADING_AGENT_PRIVATE_KEY=
DATA_AGENT_PRIVATE_KEY=
